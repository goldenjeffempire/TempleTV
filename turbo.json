{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "!src/**/*.test.*", "tsconfig*.json"],
      "outputs": ["dist/**", "web-dist/**", ".next/**", "!.next/cache/**"]
    },
    "build:tizen": {
      "dependsOn": ["^build"],
      "outputs": ["dist/tizen/**", "tizen/*.wgt"]
    },
    "build:lg": {
      "dependsOn": ["^build"],
      "outputs": ["dist/lg/**", "lg/*.ipk"]
    },
    "build:firetv": {
      "dependsOn": ["^build"],
      "outputs": ["dist/firetv/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig*.json"]
    },
    "lint": {
      "inputs": ["src/**", ".eslintrc*", "eslint.config.*"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "test/**", "*.config.*"],
      "outputs": ["coverage/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    }
  },
  "globalEnv": [
    "NODE_ENV",
    "APP_ENV",
    "EXPO_PUBLIC_API_URL",
    "EXPO_PUBLIC_PLATFORM",
    "VITE_API_URL",
    "SENTRY_DSN",
    "SENTRY_AUTH_TOKEN"
  ],
  "globalPassThroughEnv": [
    "TURBO_TOKEN",
    "TURBO_TEAM",
    "TURBO_REMOTE_CACHE_SIGNATURE_KEY",
    "CI",
    "GITHUB_ACTIONS"
  ]
}
