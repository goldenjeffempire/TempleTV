# ═══════════════════════════════════════════════════════════════════════════════
# Temple TV — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Secrets (marked [SECRET]) should be stored in Replit Secrets, GitHub Secrets,
# or your CI provider's secret store — never in plain text.

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
APP_ENV=development                         # development | staging | production
PORT=5000
LOG_LEVEL=info                              # fatal | error | warn | info | debug | trace

# ── Database (Replit auto-manages these — do not set manually on Replit) ──────
DATABASE_URL=postgresql://user:pass@host:5432/templetv
# PGHOST=
# PGPORT=5432
# PGUSER=
# PGPASSWORD=
# PGDATABASE=

# ── Authentication [SECRET] ───────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-32-chars-minimum-required
JWT_REFRESH_SECRET=change-me-32-chars-minimum-required
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
JWT_ALGORITHM=HS256
REFRESH_TOKEN_STRICT_IP_CHECK=false

# ── Admin API [SECRET] ────────────────────────────────────────────────────────
ADMIN_API_TOKEN=                            # min 16 chars; required in production
ADMIN_API_TOKEN_ROLE=editor
# ADMIN_API_TOKEN_IP_ALLOWLIST=

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=*
# CORS_ORIGINS_EXTRA=https://staging.templetv.org.ng

# ── Redis (optional — falls back to PostgreSQL without it) ────────────────────
# REDIS_URL=redis://localhost:6379

# ── SMTP / Email [SECRET] ─────────────────────────────────────────────────────
SMTP_HOST=mail.jctm.org.ng
SMTP_PORT=587
SMTP_USER=info@jctm.org.ng
SMTP_PASS=                                  # [SECRET]
SMTP_FROM_NAME=Temple TV | JCTM
SMTP_SECURE=false
APP_BASE_URL=http://localhost:5000

# ── Web Push / VAPID [SECRET] ─────────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=                          # [SECRET]
VAPID_MAILTO=mailto:admin@templetv.org.ng

# ── Expo Push [SECRET] ────────────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=                          # [SECRET]

# ── YouTube [SECRET] ──────────────────────────────────────────────────────────
YOUTUBE_API_KEY=                            # [SECRET] YouTube Data API v3
YOUTUBE_SYNC_INTERVAL_MINS=15
YOUTUBE_SYNC_DISABLE=false

# ── Sentry [SECRET] ───────────────────────────────────────────────────────────
SENTRY_DSN=                                 # [SECRET]
SENTRY_AUTH_TOKEN=                          # [SECRET] for source-map uploads
SENTRY_ORG=templetv
SENTRY_PROJECT=temple-tv-api

# ── AWS S3 + CloudFront [SECRET] ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=                          # [SECRET]
AWS_SECRET_ACCESS_KEY=                      # [SECRET]
AWS_REGION=eu-north-1
S3_BUCKET=temple-tv-media-storage
CDN_BASE_URL=                               # https://cdn.templetv.org.ng

# ── Firebase [SECRET] ─────────────────────────────────────────────────────────
# GOOGLE_SERVICES_JSON_BASE64=              # [SECRET] base64-encoded google-services.json
# GOOGLE_SERVICE_INFO_PLIST_BASE64=         # [SECRET] base64-encoded GoogleService-Info.plist

# ── HLS Streaming ────────────────────────────────────────────────────────────
REQUIRE_HLS_TOKEN=false
# HLS_TOKEN_SECRET=                         # [SECRET] required if REQUIRE_HLS_TOKEN=true
HLS_TOKEN_TTL_SECONDS=3600
# Max concurrent HLS segment requests served from PostgreSQL BYTEA storage.
# CRITICAL: each request allocates a 16 MiB pg hex string in the V8 heap PLUS
# an 8 MiB external Buffer.  Must satisfy: N × 16 MiB ≤ 80% of --max-old-space-size.
#   460 MiB heap (dev/free-tier)  → max 23, safe default 10
#   900 MiB heap (2 GiB instance) → max 45, recommended 20
#   Set CDN_BASE_URL to offload segment traffic entirely from this server.
HLS_MAX_CONCURRENT=10

# ── Transcoder ────────────────────────────────────────────────────────────────
TRANSCODER_POLL_MS=10000
TRANSCODER_DISABLE=false
# TRANSCODER_SCRATCH_DIR=/tmp/transcoder

# ── Broadcast ────────────────────────────────────────────────────────────────
BROADCAST_PRELOAD_LEAD_MS=15000
# BROADCAST_FAILOVER_HLS_URL=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT_PER_MINUTE=120
RATE_LIMIT_AUTH_PER_MINUTE=20
MAX_SSE_PER_IP=8

# ── Process Role ─────────────────────────────────────────────────────────────
RUN_MODE=all                                # api | worker | all

# ── Deployment ───────────────────────────────────────────────────────────────
# RENDER_DEPLOY_HOOK_URL=                   # [SECRET]
# RENDER_ROLLBACK_HOOK_URL=                 # [SECRET]
# API_HEALTHCHECK_URL=https://api.templetv.org.ng/api/healthz

# ── TV Platforms ──────────────────────────────────────────────────────────────
TV_CDN_URL=https://tv.templetv.org.ng
SAMSUNG_TV_PACKAGE_ID=JCTMTV001
LG_TV_APP_ID=com.templetv.jctm
