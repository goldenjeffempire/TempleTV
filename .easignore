# Root-level EAS build ignore
# Only the mobile app and its workspace dependencies are needed.
# Everything else is excluded to keep the archive small and fast.

# ── Global exclusions ───────────────────────────────────────────────────────
node_modules/
.expo/
dist/
*.tsbuildinfo
.env
.env.*
.DS_Store
*.log

# ── Server / API (not needed for mobile build) ─────────────────────────────
artifacts/api-server/
artifacts/admin/
artifacts/tv/
artifacts/mockup-sandbox/

# ── Database / spec / other libs (not direct mobile deps) ──────────────────
lib/db/
lib/api-spec/
lib/api-zod/

# ── Local agent state ──────────────────────────────────────────────────────
.local/

# ── Build outputs ──────────────────────────────────────────────────────────
artifacts/*/dist/
artifacts/*/build/
lib/*/dist/

# ── Misc ───────────────────────────────────────────────────────────────────
.git/
scripts/
RELEASE_PIPELINE.md
CHANGELOG.md
turbo.json

# ─── What IS included ──────────────────────────────────────────────────────
# package.json            (workspace root — needed for pnpm workspace config)
# pnpm-workspace.yaml     (workspace package resolution)
# pnpm-lock.yaml          (lockfile for reproducible installs on EAS server)
# artifacts/mobile/       (the mobile app itself)
# lib/player-core/        (@workspace/player-core dep)
# lib/broadcast-sync/     (@workspace/broadcast-sync dep)
# lib/broadcast-types/    (@workspace/broadcast-types dep)
# lib/api-client-react/   (@workspace/api-client-react dep)
