# ===== Core =====
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# ===== Database =====
# Provided automatically by Replit/Render. Required.
DATABASE_URL=postgres://user:pass@host:5432/dbname

# ===== Database connection pool =====
# Maximum number of PostgreSQL pool connections (default: 20).
DB_POOL_MAX=20

# ===== Auth (JWT + refresh rotation) =====
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-64-byte-hex-secret
JWT_REFRESH_SECRET=replace-with-different-64-byte-hex-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
ADMIN_API_TOKEN=replace-with-long-random-admin-bearer-token

# ===== CORS =====
# Comma-separated list of allowed origins (or "*" in dev).
CORS_ORIGINS=*

# ===== Cache (Redis optional, PostgreSQL fallback active) =====
REDIS_URL=

# ===== Object storage (S3-compatible) =====
S3_BUCKET=temple-tv-media-storage
S3_REGION=eu-north-1
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
S3_PUBLIC_URL_BASE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ===== Broadcast engine =====
# Milliseconds before the next item to begin preloading it into the inactive slot.
BROADCAST_PRELOAD_LEAD_MS=15000
# HLS failover stream URL — used when the primary broadcast URL fails.
# e.g. https://cdn.example.com/fallback/master.m3u8
BROADCAST_FAILOVER_HLS_URL=

# ===== SSE / Real-time =====
# Maximum concurrent SSE connections per client IP (default: 8).
MAX_SSE_PER_IP=8

# ===== Rate limiting =====
RATE_LIMIT_DEFAULT_PER_MINUTE=120
RATE_LIMIT_AUTH_PER_MINUTE=20

# ===== Observability =====
SENTRY_DSN=

# ===== Transcoder =====
# Set to "true" to disable the background HLS transcoding dispatcher.
TRANSCODER_DISABLE=false
# FFmpeg binary path (defaults to system PATH lookup).
FFMPEG_PATH=ffmpeg

# ===== Push notifications =====
# VAPID keys for Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@templetv.org.ng

# ===== YouTube integration =====
# API key for YouTube Data API v3 (channel/video metadata sync).
YOUTUBE_API_KEY=

# ===== Run mode =====
# "all"        — run API + transcoder in the same process (default, suitable for single-instance deploys)
# "api-only"   — skip the transcoder dispatcher (useful when transcoding runs as a separate worker)
# "transcoder" — run only the transcoder dispatcher (pair with api-only on a separate instance)
RUN_MODE=all
