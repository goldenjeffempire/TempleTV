{
  "name": "@workspace/api-server",
  "version": "1.0.28",
  "private": true,
  "type": "module",
  "description": "Temple TV API — production-grade Fastify backend for Web, Mobile, Smart TV, and Admin Dashboard.",
  "scripts": {
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps --import ./dist/instrument.mjs ./dist/index.mjs",
    "start:prod": "node --max-old-space-size=1536 --max-http-header-size=16384 --expose-gc --enable-source-maps --import ./dist/instrument.mjs ./dist/index.mjs",
    "start:render-free": "node --max-old-space-size=256 --max-http-header-size=16384 --expose-gc --enable-source-maps --import ./dist/instrument.mjs ./dist/index.mjs",
    "start:render-paid": "node --max-old-space-size=1536 --max-http-header-size=16384 --expose-gc --enable-source-maps --import ./dist/instrument.mjs ./dist/index.mjs",
    "typecheck": "NODE_OPTIONS='--max-old-space-size=4096' tsc -p tsconfig.json --noEmit",
    "test": "echo 'vitest not available in Replit environment'",
    "test:watch": "echo 'vitest not available in Replit environment'",
    "openapi": "node --enable-source-maps --import ./dist/instrument.mjs ./dist/openapi.mjs"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.3",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@fastify/websocket": "^11.0.2",
    "@sentry/node": "^10.51.0",
    "@workspace/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "catalog:",
    "expo-server-sdk": "^6.1.0",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "ioredis": "5.10.1",
    "jose": "^5.9.6",
    "nanoid": "^5.0.9",
    "nodemailer": "^6.9.16",
    "pg": "^8.20.0",
    "pino": "^9",
    "pino-pretty": "^13",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.58.0",
    "@opentelemetry/exporter-prometheus": "^0.57.2",
    "@opentelemetry/sdk-node": "^0.57.2",
    "prom-client": "^15.1.3",
    "web-push": "^3.6.7",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/nodemailer": "^6.4.17",
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "@types/web-push": "^3.6.4",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "ioredis-mock": "^8.9.0",
    "tsx": "catalog:",
    "ws": "^8.18.0"
  }
}
