{
  "name": "@workspace/api-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Temple TV API — production-grade Fastify backend for Web, Mobile, Smart TV, and Admin Dashboard.",
  "scripts": {
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps --import ./dist/instrument.mjs ./dist/index.mjs",
    "start:prod": "node --import ./dist/instrument.mjs ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "openapi": "node --enable-source-maps --import ./dist/instrument.mjs ./dist/openapi.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1036.0",
    "@aws-sdk/s3-request-presigner": "^3.1036.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.3",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@fastify/websocket": "^11.0.2",
    "@workspace/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "catalog:",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.0.9",
    "pg": "^8.20.0",
    "pino": "^9",
    "pino-pretty": "^13",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "tsx": "catalog:",
    "vitest": "^2.1.9"
  }
}
