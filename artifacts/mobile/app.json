{
  "expo": {
    "name": "Temple TV",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "templetv",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "description": "Stream live worship, sermons, and teachings from Temple TV JCTM Broadcasting — Jesus Christ Temple Ministry.",
    "owner": "templetv",
    "privacy": "public",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F5FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.templetv.jctm",
      "buildNumber": "1",
      "requireFullScreen": false,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "fetch",
          "remote-notification"
        ],
        "AVAudioSessionCategory": "AVAudioSessionCategoryPlayback",
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        },
        "NSUserNotificationsUsageDescription": "Temple TV uses notifications to alert you when a live broadcast or new sermon is available.",
        "NSPhotoLibraryUsageDescription": "Temple TV needs access to your photo library so you can choose a profile picture.",
        "NSPhotoLibraryAddUsageDescription": "Temple TV can save shared content (such as broadcast images) to your photo library."
      }
    },
    "android": {
      "package": "com.templetv.jctm",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon-foreground.png",
        "backgroundColor": "#F8F5FF"
      },
      "banner": "./assets/images/tv-banner.png",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.WAKE_LOCK"
      ],
      "intentFilters": [
        {
          "action": "android.intent.action.MAIN",
          "category": ["android.intent.category.LEANBACK_LAUNCHER"],
          "autoVerify": false
        },
        {
          "action": "android.intent.action.VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "templetv.org.ng",
              "pathPrefix": "/"
            }
          ],
          "category": ["android.intent.category.DEFAULT", "android.intent.category.BROWSABLE"]
        }
      ],
      "softwareKeyboardLayoutMode": "resize",
      "userInterfaceStyle": "light",
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "notification": {
      "icon": "./assets/images/icon.png",
      "color": "#6A0DAD",
      "androidMode": "collapse",
      "androidCollapsedTitle": "Temple TV"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://templetv.jctm"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#6A0DAD",
          "sounds": []
        }
      ],
      "./plugins/android-tv.js"
    ],
    "extra": {
      "router": {
        "origin": "https://templetv.org.ng"
      },
      "eas": {
        "projectId": "temple-tv-jctm"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
