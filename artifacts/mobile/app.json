{
  "expo": {
    "name": "Temple TV",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "templetv",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "description": "Stream live worship, sermons, and teachings from Temple TV JCTM Broadcasting — Jesus Christ Temple Ministry.",
    "owner": "templetv",
    "privacy": "public",
    "assetBundlePatterns": ["**/*"],
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0014"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.templetv.jctm",
      "buildNumber": "1",
      "requireFullScreen": false,
      "infoPlist": {
        "UIBackgroundModes": ["audio", "fetch", "remote-notification"],
        "AVAudioSessionCategory": "AVAudioSessionCategoryPlayback",
        "NSMicrophoneUsageDescription": "Temple TV uses the microphone for audio playback features.",
        "NSCameraUsageDescription": "Temple TV may use the camera for profile customisation.",
        "NSPhotoLibraryUsageDescription": "Temple TV may access your photo library for profile photos.",
        "NSUserTrackingUsageDescription": "This allows Temple TV to deliver personalised sermon recommendations.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSAllowsArbitraryLoads": false
      }
    },
    "android": {
      "package": "com.templetv.jctm",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0D0014"
      },
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.WAKE_LOCK"
      ],
      "softwareKeyboardLayoutMode": "resize",
      "userInterfaceStyle": "automatic",
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro"
    },
    "notification": {
      "icon": "./assets/images/icon.png",
      "color": "#6A0DAD",
      "androidMode": "collapse",
      "androidCollapsedTitle": "Temple TV"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://templetv.jctm"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#6A0DAD",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "temple-tv-jctm"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
