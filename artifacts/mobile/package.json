{
  "name": "@workspace/mobile",
  "version": "1.0.48",
  "private": true,
  "packageManager": "pnpm@10.26.1",
  "main": "./index.ts",
  "scripts": {
    "dev": "NODE_ENV=development CI=1 NODE_OPTIONS=--max-old-space-size=8192 EXPO_BASE_URL=/mobile pnpm exec expo start --port 18115",
    "build": "node scripts/build.js",
    "build:web": "NODE_OPTIONS=--max-old-space-size=8192 expo export --platform web --output-dir web-dist",
    "export:embed:android": "NODE_OPTIONS=--max-old-space-size=8192 expo export:embed --eager --platform android --dev false",
    "export:embed:ios": "NODE_OPTIONS=--max-old-space-size=8192 expo export:embed --eager --platform ios --dev false",
    "serve": "node server/serve.js",
    "typecheck": "NODE_OPTIONS='--max-old-space-size=8192' tsc -p tsconfig.json --noEmit",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "android:prebuild": "expo prebuild --platform android --no-install",
    "android:setup": "bash scripts/setup-local-properties.sh",
    "mobile:doctor": "bash scripts/doctor.sh",
    "android:reset": "bash scripts/android-reset.sh",
    "build:android": "bash scripts/doctor.sh && cd android && ./gradlew --no-daemon :app:bundleRelease && echo \"\\n.aab written to: $(pwd)/app/build/outputs/bundle/release/app-release.aab\"",
    "build:android:apk": "bash scripts/doctor.sh && cd android && ./gradlew --no-daemon :app:assembleRelease && echo \"\\nAPK written to: $(pwd)/app/build/outputs/apk/release/app-release.apk\"",
    "build:android:install": "pnpm run build:android:apk && adb install -r android/app/build/outputs/apk/release/app-release.apk && echo \"\\nInstalled app-release.apk on connected device. Launch it from your device app drawer.\"",
    "logcat": "bash scripts/logcat.sh",
    "screenshot": "bash scripts/screenshot.sh",
    "record": "bash scripts/record.sh",
    "eas:build": "GIT_INDEX_FILE=/tmp/eas-build-index bash scripts/eas-build.sh",
    "release:patch": "bash scripts/release.sh",
    "release:rollback": "bash scripts/release-rollback.sh",
    "android:clean": "cd android && ./gradlew clean",
    "android:stop": "cd android && ./gradlew --stop",
    "test": "node --import tsx/esm --test __tests__/**/*.test.ts"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo-google-fonts/inter": "^0.4.0",
    "@expo/cli": "57.0.6",
    "@expo/ngrok": "^4.1.0",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native/metro-config": "0.86.0",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@tanstack/react-query": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@ungap/structured-clone": "^1.3.3",
    "@workspace/api-client-react": "file:./vendor/api-client-react",
    "@workspace/broadcast-sync": "file:./vendor/broadcast-sync",
    "@workspace/broadcast-types": "file:./vendor/broadcast-types",
    "@workspace/player-core": "file:./vendor/player-core",
    "babel-plugin-react-compiler": "^19.0.0-beta-e993439-20250117",
    "babel-preset-expo": "~57.0.2",
    "expo-blur": "~57.0.0",
    "expo-build-properties": "~57.0.3",
    "expo-constants": "~57.0.3",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-image-picker": "~57.0.2",
    "expo-keep-awake": "~57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-router": "~57.0.4",
    "expo-screen-orientation": "~57.0.0",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "react-dom": "catalog:",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-keyboard-controller": "1.21.9",
    "react-native-reanimated": "~4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.0",
    "typescript": "~6.0.3",
    "zod": "catalog:",
    "zod-validation-error": "^3.4.0"
  },
  "dependencies": {
    "@sentry/react-native": "~7.11.0",
    "expo": "~57.0.4",
    "expo-audio": "~57.0.1",
    "expo-av": "~16.0.8",
    "expo-clipboard": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-in-app-updates": "workspace:*",
    "expo-modules-core": "~57.0.3",
    "expo-notifications": "~57.0.3",
    "expo-pip-android": "workspace:*",
    "expo-secure-store": "~57.0.0",
    "expo-updates": "~57.0.6",
    "expo-video": "~57.0.1",
    "hls.js": "^1.6.16",
    "react": "catalog:",
    "react-native": "0.86.0",
    "react-native-sse": "^1.2.1",
    "react-native-track-player": "^4.1.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "~0.10.0",
    "react-native-youtube-iframe": "^2.4.1"
  },
  "expo": {
    "install": {
      "exclude": [
        "@types/react",
        "@types/react-dom"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-track-player",
          "expo-pip-android",
          "expo-in-app-updates",
          "expo-av"
        ]
      }
    }
  }
}
