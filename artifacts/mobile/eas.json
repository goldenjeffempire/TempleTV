      }
    },
    "firetv": {
      "autoIncrement": true,
      "channel": "firetv",
      "credentialsSource": "remote",
      "node": "22.14.0",
      "android": {
        "buildType": "apk",
        "resourceClass": "medium"
      },
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://api.templetv.org.ng",
