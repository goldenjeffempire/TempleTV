      "autoIncrement": true,
      "channel": "appletv",
      "credentialsSource": "remote",
      "node": "22.14.0",
      "ios": {
        "resourceClass": "m1-medium",
        "buildConfiguration": "Release",
        "scheme": "TempleTv-tvOS"
      },
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://api.templetv.org.ng",
        "EXPO_PUBLIC_PLATFORM": "appletv",
