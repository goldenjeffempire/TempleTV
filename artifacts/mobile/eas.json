  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal",
        "releaseStatus": "completed",
        "changesNotSentForReview": true
      },
      "ios": {
        "bundleIdentifier": "com.templetv.app",
        "ascApiKeyPath": "/tmp/asc-api-key.p8"
      }
    },
    "staging": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal",
        "releaseStatus": "draft",
        "changesNotSentForReview": true
      },
      "ios": {
        "bundleIdentifier": "com.templetv.app",
        "ascApiKeyPath": "/tmp/asc-api-key.p8"
      }
    }
  }
