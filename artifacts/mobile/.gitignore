# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
web-dist/
expo-env.d.ts

# Native
ios/
android/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo
.vercel

# device captures (from `pnpm run screenshot`)
screenshots/

.env

# Google credentials — never commit either of these
google-service-account.json
google-services.json

# EAS / Android signing — NEVER commit (contains keystore passwords)
credentials.json
credentials/
upload_certificate.pem
*.keystore
android/keystore.properties
android/upload_certificate.pem

# Prevent a stray standalone pnpm-lock.yaml from shadowing the workspace root lockfile
# (EAS detects a nested lockfile and treats the app as standalone → frozen-lockfile fails)
pnpm-lock.yaml
