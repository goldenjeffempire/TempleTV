# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit
.cache/
.local/

# Google Play service account key (sensitive — never commit)
google-service-account.json
artifacts/mobile/google-service-account.json

# Apple signing keys (sensitive — never commit)
*.p8
apple-api-key.p8
artifacts/mobile/apple-api-key.p8

# Android keystores (sensitive — never commit)
*.jks
*.keystore
artifacts/mobile/android/keystores/

# Fastlane generated output and temp files
fastlane/output/
fastlane/screenshots/
fastlane/test_output/
fastlane/Preview.html
fastlane/report.xml

# Local signing environment (generated by keystore-setup.sh)
.env.signing

# TV platform packages (built artifacts — not source)
artifacts/tv/packages/
artifacts/tv/tizen/TempleTv.wgt
artifacts/tv/lg/*.ipk

# Firebase config files (keep templates, ignore real files)
google-services.json
GoogleService-Info.plist
artifacts/mobile/google-services.json
artifacts/mobile/GoogleService-Info.plist

# Sentry CLI config
.sentryclirc

# Docker override local configs
docker-compose.local.yml
docker-compose.override.yml
