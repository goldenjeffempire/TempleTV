modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Temple TV Admin"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Temple TV"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[[workflows.workflow]]
name = "Temple TV Admin"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=23744 BASE_PATH=/admin/ pnpm --filter @workspace/admin run dev"
waitForPort = 23744

[[workflows.workflow]]
name = "Temple TV"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=18115 pnpm --filter @workspace/mobile run dev"
waitForPort = 18115

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 18115
externalPort = 3000

[[ports]]
localPort = 18116
externalPort = 3001

[[ports]]
localPort = 23744
externalPort = 3002

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
JWT_SECRET = "06dadf631f310f88c1579ddcd3bf9287b5a8972e137cd940b8356597af8c721913737b4f3a663713ac07318944731193"
ADMIN_API_TOKEN = "1c9065c3744129eda20fa645ff86ee53bad111cc2c38e4e9bb39ecada951d9cd"
NODE_ENV = "development"
