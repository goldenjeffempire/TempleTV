modules = ["bash", "web", "nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["sh", "-c", "MALLOC_ARENA_MAX=2 PORT=8080 RUN_MODE=all NODE_ENV=production MEMORY_WARN_RSS_MB=1500 HTTP_KEEPALIVE_MS=75000 HTTP_HEADERS_TIMEOUT_MS=80000 SHUTDOWN_DRAIN_MS=10000 node --max-old-space-size=1280 --import ./artifacts/api-server/dist/instrument.mjs ./artifacts/api-server/dist/index.mjs"]
build = ["sh", "-c", "pnpm run typecheck:libs && pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/admin run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start admin"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Mobile (Expo)"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "COREPACK_ENABLE_STRICT=0 COREPACK_ENABLE_AUTO_PIN=0 pnpm install --ignore-scripts && pnpm --filter @workspace/db run push && pnpm --filter @workspace/api-server run build && PORT=5000 node --enable-source-maps --import ./artifacts/api-server/dist/instrument.mjs ./artifacts/api-server/dist/index.mjs"
waitForPort = 5000

[[workflows.workflow]]
name = "Start admin"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "COREPACK_ENABLE_STRICT=0 COREPACK_ENABLE_AUTO_PIN=0 pnpm install --ignore-scripts && PORT=3000 pnpm --filter @workspace/admin run dev"
waitForPort = 3000

[[workflows.workflow]]
name = "Mobile (Expo)"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "COREPACK_ENABLE_STRICT=0 COREPACK_ENABLE_AUTO_PIN=0 pnpm install --ignore-scripts && pnpm --filter @workspace/mobile run dev"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_object_storage:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

