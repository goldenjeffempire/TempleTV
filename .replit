modules = ["bash", "web", "postgresql-16", "nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "vm"
run = ["sh", "-c", "pnpm --filter @workspace/db run push && MALLOC_ARENA_MAX=2 PORT=8080 RUN_MODE=all NODE_ENV=production MEMORY_WARN_RSS_MB=1500 MEMORY_RESTART_RSS_MB=2500 HLS_MAX_CONCURRENT=20 HTTP_KEEPALIVE_MS=75000 HTTP_HEADERS_TIMEOUT_MS=80000 SHUTDOWN_DRAIN_MS=10000 node --max-old-space-size=2048 --expose-gc --enable-source-maps --import ./artifacts/api-server/dist/instrument.mjs ./artifacts/api-server/dist/index.mjs"]
build = ["sh", "-c", "COREPACK_ENABLE_STRICT=0 COREPACK_ENABLE_AUTO_PIN=0 pnpm install --ignore-scripts && pnpm --filter @workspace/db run push && NODE_OPTIONS='--max-old-space-size=4096' pnpm run typecheck:libs && pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/admin run build && BASE_PATH=/tv/ pnpm --filter @workspace/tv run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "CI=true COREPACK_ENABLE_STRICT=0 COREPACK_ENABLE_AUTO_PIN=0 NODE_OPTIONS='--max-old-space-size=1536' pnpm install --ignore-scripts --frozen-lockfile --filter '!@workspace/mobile' && NODE_ENV=production PORT=5000 pnpm --filter @workspace/admin run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "CI=true COREPACK_ENABLE_STRICT=0 COREPACK_ENABLE_AUTO_PIN=0 pnpm install --ignore-scripts --frozen-lockfile --filter '!@workspace/mobile' && pnpm --filter @workspace/db run push && bash scripts/build-if-changed.sh && MALLOC_ARENA_MAX=2 NODE_ENV=production PORT=8080 MEMORY_WARN_RSS_MB=1500 MEMORY_RESTART_RSS_MB=2500 HLS_MAX_CONCURRENT=10 HTTP_KEEPALIVE_MS=75000 HTTP_HEADERS_TIMEOUT_MS=80000 SHUTDOWN_DRAIN_MS=10000 node --max-old-space-size=2048 --expose-gc --enable-source-maps --import ./artifacts/api-server/dist/instrument.mjs ./artifacts/api-server/dist/index.mjs"
waitForPort = 8080

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_object_storage:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 9000
externalPort = 9000
exposeLocalhost = true

[[ports]]
localPort = 9001
externalPort = 4200

[[ports]]
localPort = 18115
externalPort = 3002

[[ports]]
localPort = 23744
externalPort = 3001

[[ports]]
localPort = 23745
externalPort = 5000

[[ports]]
localPort = 23876
externalPort = 3003

[[ports]]
localPort = 23877
externalPort = 6800

