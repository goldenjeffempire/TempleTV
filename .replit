modules = ["nodejs-20", "bash", "web"]

[deployment]
router = "application"
deploymentTarget = "vm"
run = ["sh", "-c", "pnpm --filter @workspace/db run push-force && MALLOC_ARENA_MAX=2 PORT=8080 NODE_ENV=production MEMORY_WARN_RSS_MB=1400 MEMORY_RESTART_RSS_MB=1800 MEMORY_ABSOLUTE_MAX_RSS_MB=2000 HLS_MAX_CONCURRENT=10 HTTP_KEEPALIVE_MS=75000 HTTP_HEADERS_TIMEOUT_MS=80000 SHUTDOWN_DRAIN_MS=10000 SHUTDOWN_PRECLOSE_DELAY_MS=5000 SHUTDOWN_FORCE_EXIT_BUDGET_MS=28000 node scripts/prod-supervisor.mjs"]
build = ["sh", "-c", "COREPACK_ENABLE_STRICT=0 COREPACK_ENABLE_AUTO_PIN=0 pnpm install --ignore-scripts && pnpm --filter @workspace/db run push-force && NODE_OPTIONS='--max-old-space-size=4096' pnpm run typecheck:libs && pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/admin run build && BASE_PATH=/tv/ pnpm --filter @workspace/tv run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Install and Build"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Services"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Broadcast Daemon"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/tv: web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/mockup-sandbox: Component Preview Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/admin: web"

[[workflows.workflow]]
name = "Start Services"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "export PATH=\"/home/runner/workspace/node_modules/.bin:$PATH\" && PORT=5000 pnpm --filter @workspace/admin run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "export PATH=\"/home/runner/workspace/node_modules/.bin:$PATH\" && NODE_ENV=development MALLOC_ARENA_MAX=2 MEMORY_WARN_RSS_MB=1500 MEMORY_RESTART_RSS_MB=2200 PORT=8080 RUN_MODE=all BROADCAST_DAEMON_URL=http://127.0.0.1:9000 TRANSCODER_DISABLE=1 TRANSCODING_AUTO_RETRY_DISABLE=1 NODE_OPTIONS='--max-old-space-size=768 --max-http-header-size=16384' node --expose-gc --enable-source-maps --import ./artifacts/api-server/dist/instrument.mjs ./artifacts/api-server/dist/index.mjs"
waitForPort = 8080

[[workflows.workflow]]
name = "Install and Build"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "COREPACK_ENABLE_STRICT=0 COREPACK_ENABLE_AUTO_PIN=0 pnpm install --ignore-scripts && pnpm --filter @workspace/db run push-force && NODE_OPTIONS='--max-old-space-size=4096' pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/admin run build && echo 'BUILD COMPLETE'"

[[workflows.workflow]]
name = "artifacts/tv: web"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "COREPACK_ENABLE_STRICT=0 COREPACK_ENABLE_AUTO_PIN=0 pnpm install --ignore-scripts && PORT=23744 pnpm --filter @workspace/tv run dev"
waitForPort = 23744

[[workflows.workflow]]
name = "artifacts/mockup-sandbox: Component Preview Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "COREPACK_ENABLE_STRICT=0 COREPACK_ENABLE_AUTO_PIN=0 pnpm install --ignore-scripts && PORT=23877 pnpm --filter @workspace/mockup-sandbox run dev"
waitForPort = 23877

[[workflows.workflow]]
name = "artifacts/mobile: expo"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "COREPACK_ENABLE_STRICT=0 COREPACK_ENABLE_AUTO_PIN=0 pnpm install --ignore-scripts && pnpm --filter @workspace/mobile run dev"

[[workflows.workflow]]
name = "artifacts/admin: web"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "COREPACK_ENABLE_STRICT=0 COREPACK_ENABLE_AUTO_PIN=0 pnpm install --ignore-scripts && PORT=18116 pnpm --filter @workspace/admin run dev"
waitForPort = 18116

[[workflows.workflow]]
name = "Broadcast Daemon"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "export PATH=\"/home/runner/workspace/node_modules/.bin:$PATH\" && MALLOC_ARENA_MAX=2 MEMORY_WARN_RSS_MB=800 MEMORY_RESTART_RSS_MB=1200 PORT=9000 RUN_MODE=broadcast TRANSCODER_DISABLE=1 TRANSCODING_AUTO_RETRY_DISABLE=1 NODE_OPTIONS='--max-old-space-size=512 --max-http-header-size=16384' node --expose-gc --enable-source-maps --import ./artifacts/api-server/dist/instrument.mjs ./artifacts/api-server/dist/index.mjs"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_object_storage:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

